<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/meditime_card_white_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Left: Logo Icon & App Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/meditime_pill_icon_circle"
                android:padding="9dp"
                android:src="@drawable/ic_pill_blue" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MediTime"
                    android:textColor="#0B1C30"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Próxima dosis de hoy"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Header Right: Asistente Midi (Solo Icono) -->
        <FrameLayout
            android:id="@+id/widget_header_midi_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/meditime_midi_badge_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_midi_avatar" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Divider Line (FrameLayout permitido en RemoteViews) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#F0F4F8" />

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_calendar_blue" />

        <TextView
            android:id="@+id/widget_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Hoy: 4/4 tomadas"
            android:textColor="#4B5563"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Main Dose Display Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <!-- Status Icon Circle Done (Verde cuando NO hay dosis pendientes) -->
        <FrameLayout
            android:id="@+id/widget_status_done_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/meditime_check_circle_bg"
            android:visibility="visible">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_green" />
        </FrameLayout>

        <!-- Status Icon Circle Pending (Azul cuando SÍ hay dosis pendiente) -->
        <FrameLayout
            android:id="@+id/widget_status_pending_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/meditime_pill_icon_circle"
            android:visibility="gone">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_pill_blue" />
        </FrameLayout>

        <!-- Dose Text Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_med_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="No hay dosis pendientes"
                android:textColor="#0B1C30"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_dose_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="¡Todas tus dosis de hoy están al día! 🎉"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons Row (3 Botones: Tomada, Aplazarla, Omitirla) -->
    <LinearLayout
        android:id="@+id/widget_actions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Botón 1: Marcar como Tomada -->
        <LinearLayout
            android:id="@+id/widget_btn_take_dose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/meditime_btn_take_new_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="9dp"
            android:paddingEnd="6dp"
            android:paddingBottom="9dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_check_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Marcar como Tomada"
                android:textColor="#00875A"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botón 2: Aplazarla -->
        <LinearLayout
            android:id="@+id/widget_btn_postpone_dose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/meditime_btn_postpone_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="9dp"
            android:paddingEnd="6dp"
            android:paddingBottom="9dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_clock_amber" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Aplazarla"
                android:textColor="#D97706"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botón 3: Omitirla -->
        <LinearLayout
            android:id="@+id/widget_btn_skip_dose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/meditime_btn_skip_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="9dp"
            android:paddingEnd="6dp"
            android:paddingBottom="9dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_block_red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Omitirla"
                android:textColor="#DC2626"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
