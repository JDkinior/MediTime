<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/meditime_card_white_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Informaciones a la Izquierda -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Top Badges Row: Hora + "Plan de hoy" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/quick_widget_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/meditime_pill_badge_bg"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="--:--"
                android:textColor="#0052FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Plan de hoy"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/quick_widget_med_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="No hay dosis pendientes"
            android:textColor="#0B1C30"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quick_widget_med_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="¡Todas tus dosis de hoy están al día! 🎉"
            android:textColor="#6B7280"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Botones de Acción Iconográficos a la Derecha -->
    <LinearLayout
        android:id="@+id/quick_widget_actions_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Icono 1: Tomar (Verde) -->
        <FrameLayout
            android:id="@+id/quick_widget_btn_take"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/meditime_btn_take_new_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_green" />
        </FrameLayout>

        <!-- Icono 2: Aplazar (Amarillo) -->
        <FrameLayout
            android:id="@+id/quick_widget_btn_postpone"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/meditime_btn_postpone_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_clock_amber" />
        </FrameLayout>

        <!-- Icono 3: Omitir (Rojo) -->
        <FrameLayout
            android:id="@+id/quick_widget_btn_skip"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/meditime_btn_skip_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_block_red" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
